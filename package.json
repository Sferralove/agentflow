{
  "name": "@sferralove/agent-flow-plugin",
  "version": "1.0.1",
  "description": "OpenCode plugin for automatic agent flow monitoring — no agent cooperation needed",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && npm -C dashboard run build",
    "build:dashboard": "npm -C dashboard run build",
    "dev:dashboard": "npm -C dashboard run dev",
    "prepublishOnly": "npm run build",
    "test": "find src -name '*.test.ts' -exec tsx --test {} +",
    "lint": "eslint src/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/angelosferra/agent-flow-plugin.git"
  },
  "bugs": {
    "url": "https://github.com/angelosferra/agent-flow-plugin/issues"
  },
  "homepage": "https://github.com/angelosferra/agent-flow-plugin#readme",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "*"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "eslint": "^10.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.59.2"
  },
  "keywords": [
    "opencode",
    "plugin",
    "monitoring",
    "agent-flow"
  ],
  "license": "MIT",
  "dependencies": {
    "express": "^5.2.1",
    "ws": "^8.20.0"
  }
}
